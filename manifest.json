{
  "manifest_version": 3,
  "name": "Facebook Marketplace AI Lister",
  "short_name": "AI Lister",
  "version": "1.0.0",
  "description": "Instantly generate Facebook Marketplace listings with AI. Upload a photo and get title, price, description, and category auto-filled.",
  "author": "womendemiao@gmail.com",
  "homepage_url": "https://github.com/liheyang001",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.facebook.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Marketplace Lister"
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/marketplace/create/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}
